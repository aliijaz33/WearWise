{
  "expo": {
    "name": "WearWise",
    "slug": "wearwise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wearwise",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wearwise.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "WearWise needs camera access to photograph your wardrobe items.",
        "NSPhotoLibraryUsageDescription": "WearWise needs photo library access to upload wardrobe item photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.wearwise.app",
      "versionCode": 3,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "WearWise needs access to your photos to upload wardrobe items.",
          "cameraPermission": "WearWise needs access to your camera to photograph wardrobe items."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "34a5fa6a-97a4-40aa-a30d-050d53ed6708"
      }
    },
    "owner": "alibhai007"
  }
}
